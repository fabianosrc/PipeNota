# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
# indent_size = intentionally not specified in this section
end_of_line = crlf
indent_style = space
insert_final_newline = true

# PowerShell files
[*.{ps1,psd1,psm1}]
indent_size = 4

# Markdown
[*.md]
indent_size = 2
